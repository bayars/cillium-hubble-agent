FROM python:3.11-alpine

# kubectl for exec-ing into pods to read /proc/net/dev
RUN apk add --no-cache curl && \
    curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl" && \
    chmod +x kubectl && mv kubectl /usr/local/bin/ && \
    rm -rf /var/cache/apk/*

# redis: for write_to_redis(); no kubernetes python package needed (uses kubectl binary)
RUN pip install --no-cache-dir redis

WORKDIR /app

# Copy the sidecar package (collector.py + common.py + __init__.py)
# connectivity.py is also copied — it's unused by collector but harmless
COPY sidecar/ /app/sidecar/

ENV API_PORT=9000
ENV LOG_LEVEL=INFO

EXPOSE 9000

CMD ["python", "-u", "-m", "sidecar.collector"]
